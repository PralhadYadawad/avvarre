{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/hook-bootstrap.cjs\""
      },
      {
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/hook-context-loader.cjs\""
      },
      {
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/hook-skill-suggest.cjs\""
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|editFiles|createFile|write_to_file|replace_file_content|multi_replace_file_content",
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/hook-impact-warn.cjs\""
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node \"${CLAUDE_PLUGIN_ROOT}/hook-session-end.cjs\""
      }
    ]
  }
}
