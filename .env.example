# ============================================================
# avvarre AI Configuration
# ============================================================
# Choose ONE of the two options below.

# ──────────────────────────────────────────────────────────────
# OPTION A: Universal (Any OpenAI-compatible provider)
# ──────────────────────────────────────────────────────────────
# Works with: OpenAI, Groq, Together AI, Fireworks, Mistral,
#             Ollama (local), LM Studio (local), any proxy, etc.
#
# Just set these 3 variables:

AI_BASE_URL=https://api.groq.com/openai/v1
AI_API_KEY=your-api-key-here
AI_MODEL=openai/gpt-oss-120b

# Examples for other providers:
#
# OpenAI:
#   AI_BASE_URL=https://api.openai.com/v1
#   AI_API_KEY=sk-...
#   AI_MODEL=gpt-4o
#
# Together AI:
#   AI_BASE_URL=https://api.together.xyz/v1
#   AI_API_KEY=...
#   AI_MODEL=meta-llama/Llama-3-70b-chat-hf
#
# Fireworks AI:
#   AI_BASE_URL=https://api.fireworks.ai/inference/v1
#   AI_API_KEY=...
#   AI_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct
#
# Ollama (local, free):
#   AI_BASE_URL=http://localhost:11434/v1
#   AI_API_KEY=ollama
#   AI_MODEL=llama3
#
# LM Studio (local, free):
#   AI_BASE_URL=http://localhost:1234/v1
#   AI_API_KEY=lm-studio
#   AI_MODEL=local-model

# ──────────────────────────────────────────────────────────────
# OPTION B: Google Gemini (uses its own SDK)
# ──────────────────────────────────────────────────────────────
# Uncomment the lines below and comment out Option A above.

# AI_PROVIDER=gemini
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_USE_GOOGLE_SEARCH=false
# GEMINI_THINKING_LEVEL=
