{
  "name": "avvarre",
  "version": "0.5.14",
  "description": "Harness the true power of agentic coding. Stop re-explaining context to your AI. Just Avvarre it: persistent memory, 650+ style rules, and self-correcting autopilot loops for autonomous agents.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "avvarre": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PralhadYadawad/avvarre.git"
  },
  "homepage": "https://github.com/PralhadYadawad/avvarre",
  "author": "PralhadYadawad <pralhadyadawad@gmail.com>",
  "files": [
    "dist/ai",
    "dist/analyzer",
    "dist/db",
    "dist/ecosystem",
    "dist/graph",
    "dist/workspace",
    "dist/index.js",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/index.js.map",
    "dist/server.js",
    "dist/server.d.ts",
    "dist/server.d.ts.map",
    "dist/server.js.map",
    "dist/types.js",
    "dist/types.d.ts",
    "dist/types.d.ts.map",
    "dist/types.js.map",
    "cursor-plugin/",
    "claude-plugin/",
    "antigravity-plugin/",
    "awesome-copilot/",
    "opencode-plugin/",
    "plugins/avvarre/",
    ".agents/plugins/marketplace.json",
    "README.md",
    "LICENSE",
    "CLAUDE.md",
    ".cursorrules",
    ".env.example"
  ],
  "scripts": {
    "build": "tsc && npm run postbuild",
    "postbuild": "node -e \"const fs=require('fs'),p=require('path');const pairs=[['src/analyzer/rules/python_ast.py','dist/analyzer/rules/python_ast.py'],['src/analyzer/rules/go_ast.go','dist/analyzer/rules/go_ast.go'],['src/db/schema.sql','dist/db/schema.sql']];pairs.forEach(([s,d])=>{if(fs.existsSync(s)){fs.mkdirSync(p.dirname(d),{recursive:true});fs.copyFileSync(s,d);console.log('Copied',s,'->',d)}})\"",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "plugin:toggle": "node scripts/toggle-claude-plugin.cjs"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "cursor",
    "cursorrules",
    "claude",
    "claude-code",
    "claudecode",
    "copilot",
    "github-copilot",
    "vibe-coding",
    "vibecoding",
    "ai-agent",
    "agentic",
    "ai-memory",
    "context-window",
    "code-quality",
    "linter",
    "tree-sitter",
    "ast",
    "google-style-guide",
    "local-first",
    "developer-experience"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=22.5.0"
  },
  "dependencies": {
    "@google/generative-ai": "0.21.0",
    "@modelcontextprotocol/sdk": "1.27.1",
    "openai": "6.25.0",
    "tree-sitter-wasms": "^0.1.13",
    "web-tree-sitter": "^0.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0"
  }
}
